{
  "tasks": {
    "start": "deno run --allow-all src/index.ts",
    "dev": "deno run --allow-all --watch src/index.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/index.ts src/server.ts",
    "test": "deno test --allow-all"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
